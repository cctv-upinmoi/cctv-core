<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-restructure-jobs-subscribers" author="smart-cctv">

        <!-- Drop old jobs table (had subscriber_id FK, channels, zone_names) -->
        <dropTable tableName="jobs"/>

        <!-- New jobs table — independent, no subscriber FK, no zone_names -->
        <createTable tableName="jobs">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="camera_id" type="VARCHAR(255)"/>
            <column name="camera_name" type="VARCHAR(255)"/>
            <column name="alert_types" type="TEXT" defaultValue="[]"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex tableName="jobs" indexName="idx_jobs_camera_id">
            <column name="camera_id"/>
        </createIndex>

        <!-- subscriber_jobs — M:N join table -->
        <createTable tableName="subscriber_jobs">
            <column name="subscriber_id" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="fk_subjobs_subscriber"
                             references="subscribers(id)"
                             deleteCascade="true"/>
            </column>
            <column name="job_id" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="fk_subjobs_job"
                             references="jobs(id)"
                             deleteCascade="true"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="subscriber_jobs"
                       columnNames="subscriber_id,job_id"
                       constraintName="pk_subscriber_jobs"/>

        <rollback>
            <dropTable tableName="subscriber_jobs"/>
            <dropTable tableName="jobs"/>
        </rollback>

    </changeSet>

</databaseChangeLog>

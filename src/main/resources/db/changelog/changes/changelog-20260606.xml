<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-init-schema" author="smart-cctv">

        <!-- Enable pgcrypto for gen_random_uuid() -->
        <sql>CREATE EXTENSION IF NOT EXISTS "pgcrypto";</sql>

        <!-- cameras -->
        <createTable tableName="cameras">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="ip" type="VARCHAR(100)"/>
            <column name="port" type="INTEGER"/>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="pwd" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="mode" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="rtsp_stream_url" type="TEXT"/>
            <column name="longitude" type="DOUBLE PRECISION"/>
            <column name="latitude" type="DOUBLE PRECISION"/>
            <column name="address" type="TEXT"/>
            <column name="ward" type="VARCHAR(255)"/>
            <column name="district" type="VARCHAR(255)"/>
            <column name="province" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
        </createTable>

        <!-- zones -->
        <createTable tableName="zones">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="camera_id" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="fk_zones_camera"
                             references="cameras(id)"
                             deleteCascade="true"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="type" type="VARCHAR(50)"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="points" type="JSONB" defaultValueComputed="'[]'::jsonb">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="zones" indexName="idx_zones_camera_id">
            <column name="camera_id"/>
        </createIndex>

        <!-- notifications -->
        <createTable tableName="notifications">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="camera_id" type="VARCHAR(255)"/>
            <column name="camera_name" type="VARCHAR(255)"/>
            <column name="zone_name" type="VARCHAR(255)"/>
            <column name="confidence" type="DOUBLE PRECISION"/>
            <column name="detected_at" type="TIMESTAMPTZ"/>
            <column name="image_url" type="TEXT"/>
            <column name="alert_type" type="VARCHAR(100)"/>
            <column name="person_count" type="INTEGER"/>
            <column name="event_id" type="VARCHAR(255)">
                <constraints unique="true"/>
            </column>
            <column name="read" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
        </createTable>
        <createIndex tableName="notifications" indexName="idx_notifications_camera_id">
            <column name="camera_id"/>
        </createIndex>
        <createIndex tableName="notifications" indexName="idx_notifications_detected_at">
            <column name="detected_at" descending="true"/>
        </createIndex>
        <createIndex tableName="notifications" indexName="idx_notifications_read">
            <column name="read"/>
        </createIndex>
        <createIndex tableName="notifications" indexName="idx_notifications_alert_type">
            <column name="alert_type"/>
        </createIndex>

        <!-- subscribers -->
        <createTable tableName="subscribers">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(255)"/>
            <column name="telegram_chat_id" type="VARCHAR(100)"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
        </createTable>

        <!-- jobs -->
        <createTable tableName="jobs">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscription_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="subscriber_id" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="fk_jobs_subscriber"
                             references="subscribers(id)"
                             deleteCascade="true"/>
            </column>
            <column name="camera_id" type="VARCHAR(255)"/>
            <column name="camera_name" type="VARCHAR(255)"/>
            <column name="zone_names" type="JSONB" defaultValueComputed="'[]'::jsonb"/>
            <column name="alert_types" type="JSONB" defaultValueComputed="'[]'::jsonb"/>
            <column name="channels" type="JSONB" defaultValueComputed="'[]'::jsonb"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex tableName="jobs" indexName="idx_jobs_subscriber_id">
            <column name="subscriber_id"/>
        </createIndex>
        <createIndex tableName="jobs" indexName="idx_jobs_camera_id">
            <column name="camera_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="jobs"/>
            <dropTable tableName="subscribers"/>
            <dropTable tableName="notifications"/>
            <dropTable tableName="zones"/>
            <dropTable tableName="cameras"/>
            <sql>DROP EXTENSION IF EXISTS "pgcrypto";</sql>
        </rollback>

    </changeSet>

</databaseChangeLog>
